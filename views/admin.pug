extends ./layout/index

block contenido
  h1(class="bg-white border-b-4 border-sky-400 p-4 md:p-5 text-center font-extrabold text-xl md:text-2xl uppercase tracking-wider shadow-sm") REGISTRO DE INVENTARIO
  
  div(class="py-5 md:py-10 bg-gray-50 min-h-screen px-4")
    div(class="max-w-4xl mx-auto")
      //- Cambiamos a flex-col para móvil y flex-row para escritorio
      form(action=`/mostrarTabla` method="GET" class="flex flex-col md:flex-row gap-4 items-stretch md:items-end bg-white p-6 shadow-lg rounded-xl border border-gray-100")
        
        //- Contenedor Colector
        div(class="flex-1")
          label(for="colector" class="block font-bold text-gray-700 uppercase text-xs tracking-wide") Colector:
          select#colector(name="colector" class="p-3 mt-2 w-full border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-400 bg-gray-50 transition cursor-pointer")
            option(value="") -- Seleccione --
            if colectores 
              each colector in colectores
                option(value=colector.COLECTOR_ID selected= datos ? (datos.colector == colector.COLECTOR_ID) : false) #{colector.COLECTOR}
            else
              option(value="1") No encontrado

        //- Contenedor Zona
        div(class="flex-1")
          label(for="zona" class="block font-bold text-gray-700 uppercase text-xs tracking-wide") Zona:
          select#zona(name="zona" class="p-3 mt-2 w-full border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-sky-400 bg-gray-50 transition cursor-pointer")
            option(value="") -- Seleccione --
            if zonas 
              each zona in zonas
                option(value=zona.ZONA_ID selected= datos ? (datos.zona == zona.ZONA_ID) : false) #{zona.ZONA}
            else
              option(value="1") No encontrado

        //- Botón de búsqueda (Ancho completo en móvil)
        div(class="pt-2 md:pt-0")
          button(type="submit" class="w-full md:w-auto bg-sky-600 text-white px-8 py-3 rounded-lg font-bold hover:bg-sky-700 transition-colors shadow-md active:scale-95 flex items-center justify-center gap-2")
            svg(xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor")
              path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z")
            | Buscar

               

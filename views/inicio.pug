extends ./layout/index

block contenido
  //- Título con sombra suave para dar profundidad
  h1(class="bg-white border-b-4 border-sky-400 p-5 text-center font-extrabold text-2xl uppercase tracking-wider shadow-sm") REGISTRO DE INVENTARIO
    h2(class='text-3xl font-extrabold text-center my-10')= pagina
  
  //- Contenedor centrado y con espacio
  div(class="py-10 bg-gray-50 min-h-screen")
    if errores
      div(class="max-w-md mx-auto mb-5")
        each error in errores
          p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold.rounded-md= error.msg
    div(class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-md border border-gray-100")
        form(action="/" method="POST")
            //- Fila de Almacen y Colector (Corregida)
            div(class="flex items-center space-x-4 mt-5")
                label(for="almacen" class="font-bold text-gray-700 uppercase text-sm w-24") Almacen:
                select#almacen(
                    name="almacen"
                    class="p-3 w-1/3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200 bg-white"
                )
                    option(value="") -- Seleccione --
                    if almacenes 
                        each almacen in almacenes
                            option(value=almacen.id selected= datos ? datos.almacen == almacen.id : false) #{almacen.nombre}
                    else
                        option(value="1") ALMACEN
                        option(value="2") TIENDA
                        option(value="3") HIDALGO

                
                label(for="colector" class="font-bold text-gray-700 uppercase text-sm w-24") Colector:
                select#colector(
                    name="colector"
                    class="p-3 w-1/3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200 bg-white"
                )
                    option(value="") -- Seleccione --
                    if colectores 
                        each colector in colectores
                            option(value=colector.COLECTOR selected= datos ? datos.colector == colector.id : false) #{colector.COLECTOR}
                    else
                        option(value="1") No encontrado
            div(class="flex items-center space-x-4 mt-5")
                label(for="zona" class="font-bold text-gray-700 uppercase text-sm w-24") Zona:
                input#zona(
                type="text"
                value= datos ? datos.zona : ''
                name="zona"
                class="flex-1 p-3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200"
                placeholder="Nombre de la zona")
            div(class="flex items-center space-x-4 mt-5")
                label(for="codigo" class="font-bold text-gray-700 uppercase text-sm w-24") Código:
                input#codigo(
                type="text"
                name="codigo"
                class="p-3 w-1/5 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200"
                placeholder="Código")
                input#descripcion(
                type="text"
                name="descripcion"
                readonly
                class="flex-1 p-3 cursor-not-allowed border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200"
                placeholder="Descripción")
            div(class="flex items-center space-x-4 mt-5")
                label(for="cantidad" class="font-bold text-gray-700 uppercase text-sm w-24") Cantidad:
                input#cantidad(
                type="text"
                name="cantidad"
                value= datos ? datos.cantidad : ''
                class="p-3 w-1/5 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition duration-200"
                placeholder="Cantidad")
            div(class="flex items-center space-x-4 mt-5")
                button#btnGuardar(type="submit" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-3 px-10 rounded-lg shadow-lg uppercase text-sm tracking-widest transition duration-300 ease-in-out transform hover:-translate-y-1 active:scale-95 focus:outline-none focus:ring-4 focus:ring-sky-200") Guardar Registro de Inventario
//- Al final de inicio.pug
block scripts
    script(src="/js/cargarArticulo.js")
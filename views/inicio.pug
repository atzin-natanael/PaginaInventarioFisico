extends ./layout/index

block contenido
  //- Título: Ajustamos el padding y tamaño de texto para móvil
  h1(class="bg-white border-b-4 border-sky-400 p-4 md:p-5 text-center font-extrabold text-xl md:text-2xl uppercase tracking-wider shadow-sm") REGISTRO DE INVENTARIO
  
  div(class="py-5 md:py-10 bg-gray-50 min-h-screen px-4")
    if errores
      div(class="max-w-md mx-auto mb-5")
        each error in errores
          p.bg-red-600.text-white.uppercase.text-xs.text-center.p-2.mb-1.font-bold.rounded-md= error.msg

    //- Contenedor: max-w-4xl en PC, w-full en móvil
    div(class="max-w-4xl mx-auto bg-white p-6 md:p-8 rounded-lg shadow-md border border-gray-100")
        form(action=`/` method="POST")
            
            //- Fila Almacén y Colector: Se apilan en móvil, se alinean en PC
            div(class="flex flex-col md:flex-row md:items-center gap-4 mt-5")
                div(class="flex flex-col md:flex-row md:items-center flex-1 gap-2")
                    label(for="almacen" class="font-bold text-gray-700 uppercase text-xs md:text-sm md:w-24") Almacen:
                    select#almacen(name="almacen" class="p-3 w-full border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 bg-white transition")
                        option(value="") -- Seleccione --
                        option(value="ALMACEN" selected= datos ? datos.almacen == "ALMACEN" : false) ALMACEN
                        option(value="TIENDA" selected= datos ? datos.almacen == "TIENDA" : false) TIENDA
                        option(value="HIDALGO" selected= datos ? datos.almacen == "HIDALGO" : false) HIDALGO

                div(class="flex flex-col md:flex-row md:items-center flex-1 gap-2")
                    label(for="colector" class="font-bold text-gray-700 uppercase text-xs md:text-sm md:w-24") Colector:
                    select#colector(name="colector" class="p-3 w-full border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400 bg-white transition")
                        option(value="") -- Seleccione --
                        if colectores 
                            each colector in colectores
                                option(value=colector.COLECTOR_ID selected= datos ? (datos.colector == colector.COLECTOR_ID) : false) #{colector.COLECTOR}
                        else
                            option(value="1") No encontrado

            //- Zona: Ocupa todo el ancho disponible
            div(class="flex flex-col md:flex-row md:items-center gap-2 mt-5")
                label(for="zona" class="font-bold text-gray-700 uppercase text-xs md:text-sm md:w-24") Zona:
                input#zona(type="text" value= datos ? datos.zona : '' name="zona" class="flex-1 p-3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400" placeholder="Nombre de la zona")

            //- Código y Descripción: En móvil uno arriba del otro, en PC el código es corto y la descripción larga
            div(class="flex flex-col md:flex-row md:items-center gap-4 mt-5")
                div(class="flex flex-col md:flex-row md:items-center md:w-1/3 gap-2")
                    label(for="codigo" class="font-bold text-gray-700 uppercase text-xs md:text-sm md:w-24") Código:
                    input#codigo(type="text" name="codigo" class="w-full p-3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400" placeholder="Código")
                
                div(class="flex flex-col flex-1")
                    input#descripcion(type="text" name="descripcion" readonly class="w-full p-3 bg-gray-100 border border-gray-200 rounded-md cursor-not-allowed" placeholder="Descripción del producto")

            //- Cantidad
            div(class="flex flex-col md:flex-row md:items-center gap-2 mt-5")
                label(for="cantidad" class="font-bold text-gray-700 uppercase text-xs md:text-sm md:w-24") Cantidad:
                input#cantidad(type="text" name="cantidad" value= datos ? datos.cantidad : '' class="w-full md:w-32 p-3 border border-gray-200 rounded-md focus:outline-none focus:ring-2 focus:ring-sky-400" placeholder="0")

            //- Botón: w-full para que sea fácil de presionar con el pulgar
            div(class="mt-8")
                button#btnGuardar(type="submit" class="w-full bg-sky-500 hover:bg-sky-600 text-white font-bold py-4 px-10 rounded-lg shadow-lg uppercase text-sm tracking-widest transition duration-300 transform active:scale-95") Guardar Registro

block scripts
    script.
        window.API_URL = "#{apiUrl}";
    script(src="/js/cargarArticulo.js")